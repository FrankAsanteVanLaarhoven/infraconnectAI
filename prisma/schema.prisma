generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum MemoryLevel {
  L0
  L1
  L2
}

enum Plane {
  execution
  memory
  governance
}

enum NodeKind {
  artifact
  project
  decision
  concept
  entity
  pattern
  standard
  playbook
  policy
  constraint
  experiment
  benchmark_trace
  report
  persona_note
}

enum NodeState {
  draft
  active
  pending_review
  pending_promotion
  canonical
  conflicted
  stale
  archived
  rejected
}

enum SkillName {
  spec
  plan
  build
  test
  review
  ship
  constraint_audit
  deadline_cert
}

enum RunStatus {
  queued
  running
  passed
  failed
  blocked
  cancelled
  timed_out
  recovered
}

enum PolicyScope {
  memory
  governance
  runtime
  benchmark
  persona
}

enum PolicyStatus {
  enabled
  disabled
  shadow
}

enum ConflictType {
  semantic
  duplicate
  policy
  temporal
  version
}

enum ConflictStatus {
  open
  resolved
  dismissed
}

enum InterceptDecision {
  permit
  deny
  shadow_permit
  shadow_deny
}

enum PersonaRole {
  Mission_Commander
  Safety_Auditor
  Research_Copilot
  Executive_Assistant
}

enum PersonaSessionStatus {
  idle
  listening
  speaking
  disconnected
  closed
}

enum BenchmarkName {
  IndustrialStandard
  CaP_X
}


enum BenchmarkEpisodeStatus {
  pending
  running
  passed
  failed
  blocked
  recovered
}

enum AbstractionLayer {
  S1
  S2
  S3
  S4
}

enum AggregateType {
  node
  edge
  run
  policy
  conflict
  intercept
  persona
  episode
  health_projection
  dashboard_projection
}

model MemoryNode {
  id               String      @id @default(cuid())
  shortId          String      @unique
  slug             String      @unique
  title            String
  summary          String?
  bodyRef          String?

  level            MemoryLevel
  plane            Plane
  kind             NodeKind
  state            NodeState

  confidence       Float?
  promotionScore   Float?
  tags             String?
  createdBy        String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  lastReviewedAt   DateTime?
  expiresAt        DateTime?

  sourceNodeIds    String?
  externalSourceRefs String?
  metadata         Json?

  outgoingEdges    MemoryEdge[] @relation("EdgeFrom")
  incomingEdges    MemoryEdge[] @relation("EdgeTo")

  targetRuns       SkillRun[]   @relation("RunTargets")
  readByRuns       SkillRun[]   @relation("RunReads")
  writtenByRuns    SkillRun[]   @relation("RunWrites")

  derivedPolicies  PolicyRule[] @relation("PolicyDerivedFrom")
  conflictsAsSource Conflict[]  @relation("ConflictSource")
  conflictsAsTarget Conflict[]  @relation("ConflictTarget")
}

model MemoryEdge {
  id         String   @id @default(cuid())
  shortId    String   @unique
  fromNodeId String
  toNodeId   String
  type       String
  createdBy  String
  createdAt  DateTime @default(now())
  metadata   Json?

  fromNode   MemoryNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     MemoryNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([type])
}

model SkillRun {
  id            String    @id @default(cuid())
  shortId       String    @unique
  skill         SkillName
  status        RunStatus

  title         String?
  actorId       String
  resultSummary String?
  errorMessage  String?

  startedAt     DateTime
  finishedAt    DateTime?
  durationMs    Int?

  metrics       Json?
  metadata      Json?

  targetNodeIds String?
  readNodeIds   String?
  writeNodeIds  String?

  targetNodes   MemoryNode[] @relation("RunTargets")
  readNodes     MemoryNode[] @relation("RunReads")
  writeNodes    MemoryNode[] @relation("RunWrites")

  intercepts    RuntimeIntercept[]
  benchmarkEpisodes BenchmarkEpisode[]
}

model PolicyRule {
  id               String       @id @default(cuid())
  shortId          String       @unique
  slug             String       @unique
  name             String
  scope            PolicyScope
  status           PolicyStatus
  description      String

  appliesToLevels  String?
  appliesToPlanes  String?
  appliesToKinds   String?

  params           Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  derivedFromNodeId String?
  derivedFromNode   MemoryNode? @relation("PolicyDerivedFrom", fields: [derivedFromNodeId], references: [id])

  intercepts        RuntimeIntercept[] @relation("MatchedPolicies")

  @@index([scope, status])
}

model Conflict {
  id            String         @id @default(cuid())
  shortId       String         @unique
  type          ConflictType
  status        ConflictStatus
  severity      String
  explanation   String

  sourceNodeId  String
  targetNodeId  String

  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?
  resolvedBy    String?
  metadata      Json?

  sourceNode    MemoryNode     @relation("ConflictSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode    MemoryNode     @relation("ConflictTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}

model RuntimeIntercept {
  id               String            @id @default(cuid())
  shortId          String            @unique
  actorId          String
  policyProfile    String
  action           String
  target           String
  decision         InterceptDecision
  matchedPolicyIds String?
  matchedPolicies  PolicyRule[]      @relation("MatchedPolicies")
  reason           String
  executed         Boolean           @default(false)
  evidenceRef      String?
  createdAt        DateTime          @default(now())
  metadata         Json?

  requestedByRunId String?
  requestedByRun   SkillRun?         @relation(fields: [requestedByRunId], references: [id])

  @@index([decision])
  @@index([requestedByRunId])
}

model PersonaSession {
  id             String               @id @default(cuid())
  shortId        String               @unique
  role           PersonaRole
  status         PersonaSessionStatus
  endpoint       String
  transport      String               @default("ws")
  actorId        String

  startedAt      DateTime             @default(now())
  endedAt        DateTime?
  linkedRunIds   String?
  pushedNodeIds  String?
  metadata       Json?
}

model BenchmarkEpisode {
  id                String                 @id @default(cuid())
  shortId           String                 @unique
  benchmark         BenchmarkName
  suite             String
  taskId            String
  abstractionLayer  AbstractionLayer
  status            BenchmarkEpisodeStatus

  success           Boolean?
  policyViolationCount Int                 @default(0)
  recoveryCount     Int                    @default(0)

  traceNodeIds      String?
  importedAt        DateTime?
  metrics           Json?
  metadata          Json?

  runId             String?
  run               SkillRun?              @relation(fields: [runId], references: [id])

  @@index([benchmark, suite])
  @@index([status])
}

model DomainEvent {
  id             String        @id @default(cuid())
  eventType      String
  aggregateType  AggregateType
  aggregateId    String
  actorId        String
  timestamp      DateTime      @default(now())
  correlationId  String?
  causationId    String?
  payload        Json
  schemaVersion  Int           @default(1)

  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([timestamp])
}

model HealthProjection {
  id               String    @id @default("singleton")
  overall          Float
  policyVersion    String

  coverage         Float
  conflictDensity  Float
  staleness        Float
  redundancy       Float

  byLevel          Json
  byPlane          Json

  generatedAt      DateTime  @default(now())
  sourceEventId    String
}

model DashboardProjection {
  id                    String   @id @default("singleton")
  totalNodes            Int
  completedSkills       Int
  canonicalKnowledge    Int
  scratchItems          Int
  wikiEntries           Int
  activeConflicts       Int

  planeCounts           Json
  levelCounts           Json

  busStatus             String
  busConnections        Int

  generatedAt           DateTime @default(now())
  sourceEventId         String
}

model GovernanceProjection {
  id                    String   @id @default("singleton")
  canonCount            Int
  wikiCount             Int
  scratchCount          Int

  promotionPipeline     Json
  pendingPromotions     Json
  decayTimeline         Json

  generatedAt           DateTime @default(now())
  sourceEventId         String
}

model ActivityProjection {
  id                    String   @id @default("singleton")
  eventCount            Int
  recentEvents          Json
  generatedAt           DateTime @default(now())
  sourceEventId         String
}

model AgentBusProjection {
  id                    String   @id @default("singleton")
  status                String
  uptimeSeconds         Int
  connectionCount       Int
  topicCount            Int
  subscriptionCount     Int
  recentMessages        Json
  subscriptions         String?
  generatedAt           DateTime @default(now())
  sourceEventId         String
}

model ExplorerProjection {
  id                    String   @id @default("singleton")
  totalNodes            Int
  nodes                 Json
  filters               Json
  generatedAt           DateTime @default(now())
  sourceEventId         String
}

model PersonaProjection {
  id                    String   @id @default("singleton")
  activeSession         Json?
  availableRoles        String?
  generatedAt           DateTime @default(now())
  sourceEventId         String
}

model BenchmarkProjection {
  id                    String   @id @default("singleton")
  benchmark             BenchmarkName
  ablationMode          Boolean  @default(false)

  loaded                Boolean  @default(false)
  taskSuccess           Float?
  policyViolations      Float?
  autoRecovery          Float?
  abstractionLayer      AbstractionLayer?

  episodes              Json
  generatedAt           DateTime @default(now())
  sourceEventId         String
}

model RuntimeProjection {
  id                    String   @id @default("singleton")
  profile               String
  enforcing             Boolean
  permittedCount        Int
  blockedCount          Int
  recentIntercepts      Json
  generatedAt           DateTime @default(now())
  sourceEventId         String
}

// ─── Observatory Modules (V2) ────────────────────────────────────────────────

model AgentRegistration {
  id              String   @id @default(cuid())
  slug            String   @unique
  displayName     String
  agentType       String
  deployTier      String
  hardwareProfile String?
  orgId           String
  teamId          String?
  status          String   @default("registered")
  simPaired       String?
  lastHeartbeat   DateTime?
  heartbeatRateMs Int      @default(5000)
  capabilities    String?
  modalitySet     String?
  policyProfileId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  telemetry       AgentTelemetry[]
  constraintChecks ConstraintCheck[]
  transferEvents  TransferEvent[]
  incidents       AgentIncident[]
}

model AgentTelemetry {
  id          String   @id @default(cuid())
  agentId     String
  tick        BigInt
  ts          DateTime @default(now())
  deployTier  String
  modality    String
  payload     Json
  latencyMs   Float?
  agent       AgentRegistration @relation(fields: [agentId], references: [id])

  @@index([agentId, modality, ts])
}

model ConstraintCheck {
  id           String            @id @default(cuid())
  agentId      String
  constraintId String
  ts           DateTime          @default(now())
  deployTier   String
  value        Float
  threshold    Float
  passed       Boolean
  latencyMs    Float?
  agent        AgentRegistration @relation(fields: [agentId], references: [id])

  @@index([agentId, constraintId, ts])
}

model TransferEvent {
  id           String            @id @default(cuid())
  agentId      String
  fromTier     String
  toTier       String
  triggeredBy  String
  outcome      String?
  deltaMetrics Json?
  ts           DateTime          @default(now())
  agent        AgentRegistration @relation(fields: [agentId], references: [id])
}

model AgentIncident {
  id          String            @id @default(cuid())
  agentId     String
  severity    String
  category    String
  description String
  resolvedAt  DateTime?
  ts          DateTime          @default(now())
  agent       AgentRegistration @relation(fields: [agentId], references: [id])

  @@index([severity, ts])
}

model OrgTeamProject {
  id          String   @id @default(cuid())
  orgSlug     String
  teamSlug    String?
  projectSlug String
  plan        String   @default("dev")
  agentQuota  Int      @default(10)
  createdAt   DateTime @default(now())

  @@unique([orgSlug, teamSlug, projectSlug])
}

// ─── Agent Lifecycle & Directives (Rebranded) ───────────────────────────────

model SafetyDirective {
  id            String   @id @default(cuid())
  name          String
  severity      String
  domain        String
  lastTestedAt  DateTime?
  violations    OperationalViolation[]
}


model AgentLifecycleRun {
  id            String   @id @default(cuid())
  environment   String
  status        String
  completedAt   DateTime
  successRate   Float
  avgDeadlineMs Float
  deadlineSatisfied Boolean
}

model OperationalViolation {
  id           String           @id @default(cuid())
  directiveId  String
  directive    SafetyDirective @relation(fields: [directiveId], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime         @default(now())
}

model FleetNode {
  id          String   @id @default(cuid())
  tenantId    String   @default("SYSTEM_ROOT")
  robotId     String   @unique
  alias       String
  status      String   @default("online") // online | offline | degraded
  lastSeen    DateTime @default(now())
  memoryBytes BigInt   @default(0)
  anomalyCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // SOTA Telemetry Geospatial Matrix
  latitude    Float?
  longitude   Float?
  region      String?

  anomalies   Anomaly[]
}

model Anomaly {
  id          String    @id @default(cuid())
  tenantId    String    @default("SYSTEM_ROOT")
  nodeId      String
  node        FleetNode @relation(fields: [nodeId], references: [id])
  severity    String    // info | warn | critical
  type        String    // memory_leak | spike | corruption | timeout
  description String
  payload     Json?
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model Memory {
  id          String   @id @default(cuid())
  tenantId    String   @default("SYSTEM_ROOT")
  type        String   // "incident", "decision", "sim_vs_real_gap"
  content     Json
  createdAt   DateTime @default(now())

  @@index([type])
}

// ─── Security & Compliance Matrix ─────────────────────────────────────────────

model AiAuditLog {
  id              String   @id @default(cuid())
  user            String   // Identifier (e.g., email or actorId)
  action          String
  resource        String?
  input           String
  output          String?
  contextHash     String?
  validated       Boolean  @default(false)
  executed        Boolean  @default(false)
  confidence      Float?
  reasoning       Json?
  timestamp       DateTime @default(now())

  @@index([user])
  @@index([action])
  @@index([timestamp])
}

// ─── CRM & Enterprise Routing Subsystems ──────────────────────────────────────

model EnterpriseLead {
  id                   String   @id @default(cuid())
  clientIdentifier     String   // Raw email or username
  clientName           String
  tenantId             String   @default("GLOBAL_INTERNAL") // The exact Customer/Network ID routing this specific lead to its sandbox
  routingDesignation   String   // The mapped node e.g., 'hello', 'frank', 'security'
  intentPayload        String   
  
  // Autonomic Classifications
  leadTier             String   // 'HIGH_VALUE' | 'GENERIC'
  industryEstimation   String?  // AI-extracted industry tag
  threatLevel          String   @default("benign") // 'benign' | 'spam' | 'malicious'
  
  // Tactical Escalation Status
  status               String   @default("queued") // 'queued' | 'reviewing' | 'cleared' | 'archived'
  accessCode           String?  // Auto-generated passcode upon approval
  
  capturedAt           DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([leadTier, status])
  @@index([capturedAt])
}

model Lead {
  id              String   @id @default(cuid())
  email           String   @unique
  company         String?
  role            String?
  message         String?

  score           Int      @default(0)
  status          String   @default("new") // new, qualified, meeting, closed
  source          String?  // landing, demo, direct
  intent          String?  // high, medium, low

  // Behavioral & Firmographic Tracking
  companySize     String?
  industry        String?
  visitedDemo     Boolean  @default(false)
  viewedSecurity  Boolean  @default(false)
  replied         Boolean  @default(false)

  // AI Generated Metadata
  aiNotes         String?
  lastEmailSent   DateTime?
  nextAction      String?

  // Financials & Strategic
  projectedValue  Float?
  notes           String?
  strategicBrief  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sector          String? // e.g. 'Energy', 'Gov', 'Tech'
  region          String? // e.g. 'EMEA', 'APAC', 'US_EAST'
  lat             Float?
  lng             Float?
  activities      DealActivity[]

  @@index([score])
  @@index([status])
}

model DealActivity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  type        String   // email, demo, security_view, tactical_adjustment, manual_note
  description String
  timestamp   DateTime @default(now())

  @@index([leadId])
}

enum Sector {
  GOVERNMENT
  ENERGY
  LOGISTICS
  COMMERCIAL
  GENERAL
}

model IntelSubscription {
  id          String   @id @default(cuid())
  clientId    String   @unique
  interests   String? // e.g. ["Wildfire", "Stock Market", "Competitor acquisitions"]
  tier        String   @default("STANDARD") // STANDARD | PREMIUM | GLOBAL
  sector      Sector   @default(GENERAL)
  deviceLimit Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserDevice {
  id          String   @id @default(cuid())
  clientId    String
  fingerprint String
  label       String?
  ipAddress   String?
  lastSeen    DateTime @default(now())
  isAuthorized Boolean @default(true)

  createdAt   DateTime @default(now())

  @@unique([clientId, fingerprint])
  @@index([clientId])
}

model SecurityIncident {
  id          String   @id @default(cuid())
  clientId    String
  type        String   // e.g. "DEVICE_LIMIT_REACHED", "UNAUTHORIZED_SIGNATURE"
  fingerprint String
  ipAddress   String?
  userAgent   String?
  severity    String   @default("low") // low | medium | high | critical
  ts          DateTime @default(now())

  @@index([clientId])
  @@index([ts])
}


model EarthInsight {
  id          String   @id @default(cuid())
  category    String   // e.g. "DISEASTER", "COMMERCIAL", "SECURITY"
  title       String
  content     String
  priority    String   @default("low") // low | medium | high | emergency
  coordinates String?  // [lat, lng]
  isDelivered Boolean  @default(false)
  ts          DateTime @default(now())
}

model AcquisitionSlot {
  id          String   @id @default(cuid())
  targetName  String
  aoi         String   // Area of Interest (GeoJSON or string)
  sensorType  String   @default("SAR") // SAR | Optical | FLIR
  status      String   @default("scheduled") // scheduled | in_progress | completed | failed
  startTime   DateTime
  endTime     DateTime
  priority    Int      @default(1)
  createdAt   DateTime @default(now())
}

// ─── Intelligence Studio ──────────────────────────────────────────────────────

model EphemeralLayout {
  id          String   @id @default(cuid())
  intent      String
  title       String
  description String?
  config      Json     // EphemeralLayout structure (widgets, etc.)
  isStarred   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Humanoid Robotics MLOps & CI/CD Pipeline ─────────────────────────────────

model ML_Experiment {
  id              String   @id @default(cuid())
  modelName       String
  runTag          String
  hyperparameters Json
  rewardCurves    Json     // Array of {episode, reward, loss}
  svrRate         Float    // Safety Violation Rate
  completedAt     DateTime @default(now())

  isaacLabRuns    IsaacLabRun[]
}

model OTA_Payload {
  id              String   @id @default(cuid())
  version         String   @unique
  storageUri      String   // e.g. s3://zerogate-models/vla-1.0.whl
  manifestData    Json
  checksum        String
  createdAt       DateTime @default(now())
  
  deployments     OTA_Deployment[]
}

model OTA_Deployment {
  id              String   @id @default(cuid())
  payloadId       String
  targetTier      String
  status          String   @default("pending") // pending, rolling, completed, rolled-back
  pipelineStage   String   @default("REAL_FLEET") // SIM_L0_BASELINE, SIM_L1_HIL, REAL_FLEET
  hardwareTarget  String   @default("UNITREE_G1") // UNITREE_G1, QUAD_GENERIC, WHEELED
  autoPromote     Boolean  @default(false)
  agentSuccessIds Json     // List of agent IDs that applied successfully
  agentFailedIds  Json     // List of agent IDs that failed
  triggeredBy     String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?

  payload         OTA_Payload @relation(fields: [payloadId], references: [id])
}

// ═══════════════════════════════════════════════════════════════════════════════
// PHYSICAL AI CORE — v3.0 "Physical WeightsLab" Additions
// ═══════════════════════════════════════════════════════════════════════════════

enum IsaacRunStatus {
  QUEUED
  RUNNING
  PAUSED_FOR_DATA_ISSUE
  PAUSED_FOR_PHYSICS
  COMPLETED
  FAILED_PHYSICS
  ARCHIVED
}

enum CurationAction {
  PRUNE
  KEEP
  AUGMENT
  FLAG_HUMAN_REVIEW
  PROMOTE_TO_CANON
}

model IsaacLabRun {
  id                    String           @id @default(cuid())
  experimentId          String
  status                IsaacRunStatus   @default(QUEUED)
  sceneUsd              String           // Path to Isaac Lab USD scene
  domainRandomization   Json             // DR config (lighting, textures, physics)
  numEnvs               Int              // Number of parallel envs
  totalEpisodes         Int              @default(0)
  physicsScoreAvg       Float            @default(0)
  dataQualityScoreAvg   Float            @default(0)
  highLossCount         Int              @default(0)
  prunedCount           Int              @default(0)
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  mlExperiment          ML_Experiment    @relation(fields: [experimentId], references: [id])
  episodes              PhysicsEpisode[]
  curationEvents        DataCurationEvent[]

  @@index([status])
  @@index([experimentId])
}

model PhysicsEpisode {
  id                    String   @id @default(cuid())
  runId                 String
  episodeIndex          Int
  physicsRealism        Float    // 0-1 (collision, friction, stability)
  sensorFidelity        Float    // 0-1 (camera, LiDAR, depth accuracy)
  languageGrounding     Float    // 0-1 (VLA instruction alignment)
  actionSuccess         Float    // 0-1
  modelLoss             Float
  cleanlabConfidence    Float    // 0-1 (Cleanlab label quality)
  overallQualityScore   Float    // Weighted composite
  isPruned              Boolean  @default(false)
  pruneReason           String?
  replayUrl             String?  // 3D replay link
  memoryNodeId          String?  // Link to L1.5 Physics Canon
  createdAt             DateTime @default(now())

  run                   IsaacLabRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, episodeIndex])
  @@index([isPruned])
  @@index([overallQualityScore])
}

model DataCurationEvent {
  id             String          @id @default(cuid())
  runId          String
  episodeIds     String          // JSON array of episode IDs affected
  action         CurationAction
  reason         String
  confidence     Float
  agent          String          // "PhysicsAgent" | "CleanlabAgent" | "WeightsLabAgent" | "Human"
  metadata       Json?
  createdAt      DateTime        @default(now())

  run            IsaacLabRun     @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([action])
  @@index([createdAt])
}

model VlaTrainingSession {
  id                  String   @id @default(cuid())
  name                String
  baseModel           String   // e.g. "openvla-7b", "pi0", "gr00t-n1"
  datasetMix          Json     // { real: ["BDD100K"], synthetic: ["LIBERO"] }
  status              String   @default("queued") // queued | training | paused | completed | failed
  totalSteps          Int
  currentStep         Int      @default(0)
  bestPhysicsScore    Float?
  bestDataQuality     Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
}

model RobotModel {
  id          String   @id @default(cuid())
  name        String
  urdfContent String?
  simConfig   String?  // JSON config for Isaac Lab
  status      String   @default("IMPORTED") // IMPORTED, SYNCED, ACTIVE
  jointCount  Int      @default(0)
  linkCount   Int      @default(0)
  totalMass   Float    @default(0)
  importedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RobotTelemetry {
  id        String   @id @default(cuid())
  robotId   String
  type      String   // joint_states, battery_thermal, etc.
  data      Json
  timestamp DateTime @default(now())

  @@index([robotId])
  @@index([type])
  @@index([timestamp])
}
