{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3006",
    "distDir": "../.next"
  },
  "package": {
    "productName": "InfraConnect AI",
    "version": "2.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": false,
        "open": false
      },
      "protocol": {
        "all": false,
        "asset": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "io.infraconnect.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "InfraConnect AI Mission Control",
        "width": 1400
      }
    ]
  }
}
